generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── STAFF & AUTH ──────────────────────────────────────────────────────────

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  roleName          String             @default("STAFF") @map("role")
  roleRef           Role               @relation(fields: [roleName], references: [name])
  isActive          Boolean            @default(true)
  mustResetPassword Boolean            @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendance        Attendance[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  sales             Sale[]
  sessions          Session[]
  stockTransactions StockTransaction[]
  priceChanges      PriceHistory[]
  transfersRequested StockTransfer[]   @relation("TransferRequestedBy")
  transfersApproved  StockTransfer[]   @relation("TransferApprovedBy")
  creditSalesCreated CreditSale[]
  creditPaymentsRecorded CreditPayment[]
  ordersProcessed   Order[]
  deliveriesReceived AggregatorDelivery[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@map("audit_logs")
}

model Attendance {
  id       String    @id @default(cuid())
  userId   String
  clockIn  DateTime  @default(now())
  clockOut DateTime?
  notes    String?
  user     User      @relation(fields: [userId], references: [id])

  @@map("attendance")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  permissions Json?
  isSystem    Boolean  @default(false) @map("is_system")
  color       String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("roles")
}

// ─── WAREHOUSES & SHOPS ───────────────────────────────────────────────────

model Warehouse {
  id              String           @id @default(cuid())
  name            String
  type            WarehouseType
  location        String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  shops           Shop[]
  stocks          WarehouseStock[]
  transfersOut    StockTransfer[]  @relation("TransferFromWarehouse")
  transfersIn     StockTransfer[]  @relation("TransferToWarehouse")
  fulfilledOrders Order[]          @relation("OrderFulfillment")

  @@map("warehouses")
}

model Shop {
  id              String          @id @default(cuid())
  name            String
  warehouseId     String
  location        String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
  stocks          ShopStock[]
  sales           Sale[]
  transfersTo     StockTransfer[] @relation("TransferToShop")
  transfersFrom   StockTransfer[] @relation("TransferFromShop")
  fulfilledOrders Order[]         @relation("OrderFulfillment")

  @@map("shops")
}

// ─── PRODUCTS & CATEGORIES ────────────────────────────────────────────────

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]

  @@map("product_categories")
}

model Product {
  id                String             @id @default(cuid())
  name              String
  sku               String?            @unique
  categoryId        String
  description       String?
  imageUrl          String?
  unit              UnitType           @default(PIECE)
  costPrice         Decimal            @db.Decimal(12, 2)
  sellingPrice      Decimal            @db.Decimal(12, 2)
  lowStockThreshold Int                @default(5)
  isActive          Boolean            @default(true)
  isPublic          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  category          ProductCategory    @relation(fields: [categoryId], references: [id])
  warehouseStocks   WarehouseStock[]
  shopStocks        ShopStock[]
  stockTransactions StockTransaction[]
  stockTransfers    StockTransfer[]
  saleItems         SaleItem[]
  orderItems        OrderItem[]
  creditSaleItems   CreditSaleItem[]
  priceHistory      PriceHistory[]

  @@map("products")
}

// ─── STOCK MANAGEMENT ─────────────────────────────────────────────────────

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  lastUpdated DateTime  @default(now()) @updatedAt
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("warehouse_stocks")
}

model ShopStock {
  id          String   @id @default(cuid())
  productId   String
  shopId      String
  quantity    Int      @default(0)
  lastUpdated DateTime @default(now()) @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@unique([productId, shopId])
  @@map("shop_stocks")
}

model StockTransaction {
  id          String               @id @default(cuid())
  productId   String
  type        StockTransactionType
  quantity    Int
  note        String?
  warehouseId String?
  shopId      String?
  transferId  String?
  userId      String
  createdAt   DateTime             @default(now())
  product     Product              @relation(fields: [productId], references: [id])
  user        User                 @relation(fields: [userId], references: [id])

  @@index([productId])
  @@map("stock_transactions")
}

model StockTransfer {
  id              String         @id @default(cuid())
  productId       String
  quantity        Int
  fromWarehouseId String?
  fromShopId      String?
  toWarehouseId   String?
  toShopId        String?
  status          TransferStatus @default(PENDING)
  requestedById   String
  approvedById    String?
  notes           String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  product         Product        @relation(fields: [productId], references: [id])
  fromWarehouse   Warehouse?     @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  fromShop        Shop?          @relation("TransferFromShop", fields: [fromShopId], references: [id])
  toWarehouse     Warehouse?     @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  toShop          Shop?          @relation("TransferToShop", fields: [toShopId], references: [id])
  requestedBy     User           @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy      User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  @@map("stock_transfers")
}

model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  oldPrice    Decimal  @db.Decimal(12, 2)
  newPrice    Decimal  @db.Decimal(12, 2)
  changedById String
  reason      String?
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])
  changedBy   User     @relation(fields: [changedById], references: [id])

  @@index([productId])
  @@map("price_history")
}

// ─── SALES & POS ──────────────────────────────────────────────────────────

model SaleSession {
  id         String    @id @default(cuid())
  cashierId  String
  shopId     String?
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  totalSales Decimal   @default(0) @db.Decimal(12, 2)
  isOpen     Boolean   @default(true)
  sales      Sale[]

  @@map("sale_sessions")
}

model Sale {
  id            String        @id @default(cuid())
  sessionId     String
  cashierId     String
  shopId        String?
  customerId    String?
  total         Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())
  payments      Payment[]
  saleItems     SaleItem[]
  cashier       User          @relation(fields: [cashierId], references: [id])
  session       SaleSession   @relation(fields: [sessionId], references: [id])
  shop          Shop?         @relation(fields: [shopId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

// ─── CUSTOMERS & CRM ──────────────────────────────────────────────────────

model Customer {
  id                   String            @id @default(cuid())
  name                 String
  email                String?
  phone                String            @unique
  address              String?
  roles                CustomerRole[]
  notes                String?
  profileImageUrl      String?
  passwordHash         String?
  isEmailVerified      Boolean           @default(false)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  orders               Order[]
  sales                Sale[]
  creditSales          CreditSale[]
  creditPayments       CreditPayment[]
  aggregatorOffers     AggregatorOffer[]
  sessions             CustomerSession[]

  @@map("customers")
}

model CustomerSession {
  id         String   @id @default(cuid())
  customerId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_sessions")
}

// ─── ORDERS (PUBLIC + WALK-IN) ────────────────────────────────────────────

model Order {
  id              String         @id @default(cuid())
  orderCode       String         @unique
  customerId      String?
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryMethod  DeliveryMethod @default(PICKUP)
  deliveryAddress String?
  status          OrderStatus    @default(PENDING)
  paymentStatus   PaymentStatus  @default(UNPAID)
  subtotal        Decimal        @db.Decimal(12, 2)
  deliveryFee     Decimal        @default(0) @db.Decimal(12, 2)
  total           Decimal        @db.Decimal(12, 2)
  notes                    String?
  source                   OrderSource    @default(WEBSITE)
  processedById            String?
  fulfilledFromWarehouseId String?
  fulfilledFromShopId      String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  items                    OrderItem[]
  payments                 Payment[]
  customer                 Customer?      @relation(fields: [customerId], references: [id])
  processedBy              User?          @relation(fields: [processedById], references: [id])
  fulfilledFromWarehouse   Warehouse?     @relation("OrderFulfillment", fields: [fulfilledFromWarehouseId], references: [id])
  fulfilledFromShop        Shop?          @relation("OrderFulfillment", fields: [fulfilledFromShopId], references: [id])

  @@index([status])
  @@index([orderCode])
  @@index([customerPhone])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── CREDIT & DEBT ────────────────────────────────────────────────────────

model CreditSale {
  id                  String           @id @default(cuid())
  customerId          String
  creditType          CreditType
  totalAmount         Decimal          @db.Decimal(12, 2)
  paidAmount          Decimal          @default(0) @db.Decimal(12, 2)
  dueDate             DateTime?        @db.Date
  season              String?
  status              CreditStatus     @default(ACTIVE)
  returnedToInventory Boolean          @default(false)
  notes               String?
  createdById         String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  items               CreditSaleItem[]
  payments            CreditPayment[]
  customer            Customer         @relation(fields: [customerId], references: [id])
  createdBy           User             @relation(fields: [createdById], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("credit_sales")
}

model CreditSaleItem {
  id           String     @id @default(cuid())
  creditSaleId String
  productId    String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  total        Decimal    @db.Decimal(12, 2)
  creditSale   CreditSale @relation(fields: [creditSaleId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])

  @@map("credit_sale_items")
}

model CreditPayment {
  id           String        @id @default(cuid())
  creditSaleId String
  customerId   String
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  reference    String?
  notes        String?
  recordedById String
  createdAt    DateTime      @default(now())
  creditSale   CreditSale    @relation(fields: [creditSaleId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  recordedBy   User          @relation(fields: [recordedById], references: [id])

  @@index([creditSaleId])
  @@map("credit_payments")
}

// ─── AGGREGATOR MANAGEMENT ────────────────────────────────────────────────

model AggregatorOffer {
  id                String               @id @default(cuid())
  customerId        String
  productName       String
  quantity          Decimal              @db.Decimal(12, 2)
  unit              String
  offeredPrice      Decimal              @db.Decimal(12, 2)
  counterPrice      Decimal?             @db.Decimal(12, 2)
  counterQuantity   Decimal?             @db.Decimal(12, 2)
  agreedPrice       Decimal?             @db.Decimal(12, 2)
  agreedQuantity    Decimal?             @db.Decimal(12, 2)
  status                   OfferStatus          @default(PENDING)
  advancePaid              Decimal              @default(0) @db.Decimal(12, 2)
  totalPaid                Decimal              @default(0) @db.Decimal(12, 2)
  productImages            String[]
  agreementDocUrl          String?
  signedAgreementDocUrl    String?
  agreementRejectionReason String?
  agreementSentAt          DateTime?
  agreementSignedAt        DateTime?
  suppliedAt               DateTime?
  completedAt              DateTime?
  notes                    String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  deliveries               AggregatorDelivery[]
  negotiations             OfferNegotiation[]
  customer                 Customer             @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("aggregator_offers")
}

model OfferNegotiation {
  id        String          @id @default(cuid())
  offerId   String
  round     Int
  by        String          // "ADMIN" or "AGGREGATOR"
  action    String          // "INITIAL", "COUNTER", "COUNTER_BACK", "ACCEPT", "REJECT", etc.
  price     Decimal         @db.Decimal(12, 2)
  quantity  Decimal         @db.Decimal(12, 2)
  unit      String
  note      String?
  createdAt DateTime        @default(now())
  offer     AggregatorOffer @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@map("offer_negotiations")
}

model AggregatorDelivery {
  id                String          @id @default(cuid())
  offerId           String
  quantityDelivered Decimal         @db.Decimal(12, 2)
  unit              String
  deliveryDate      DateTime        @default(now())
  receivedById      String
  notes             String?
  offer             AggregatorOffer @relation(fields: [offerId], references: [id])
  receivedBy        User            @relation(fields: [receivedById], references: [id])

  @@map("aggregator_deliveries")
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  reference   String        @unique
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  source      PaymentSource
  status      PaymentStatus @default(UNPAID)
  valuepayRef String?
  orderId     String?
  saleId      String?
  notes       String?
  confirmedAt DateTime?
  createdAt   DateTime      @default(now())
  order       Order?        @relation(fields: [orderId], references: [id])
  sale        Sale?         @relation(fields: [saleId], references: [id])

  @@index([source, status])
  @@index([valuepayRef])
  @@index([status, confirmedAt])
  @@map("payments")
}

// ─── CONTENT & SETTINGS ───────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  mediaUrl  String?
  mediaType String?
  isActive  Boolean  @default(true)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model SiteSettings {
  id            String   @id @default("default")
  businessName  String   @default("Agro Hub")
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  googleMapsUrl String?
  openingHours  Json?
  aboutText     String?
  deliveryFee   Decimal  @default(0) @db.Decimal(12, 2)
  deliveryAreas Json?
  updatedAt     DateTime @updatedAt

  @@map("site_settings")
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  recipientId String?
  isRead      Boolean          @default(false)
  metadata    Json?
  createdAt   DateTime         @default(now())
  recipient   User?            @relation(fields: [recipientId], references: [id])

  @@index([recipientId, isRead])
  @@map("notifications")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum WarehouseType {
  AGRO_INPUT
  GRAIN
}

enum UnitType {
  PIECE
  BAG
  KG
  LITRE
  CARTON
  BOX
  BOTTLE
  SACK
}

enum TransferStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS
  ONLINE
}

enum PaymentSource {
  ORDER
  SALE
  CREDIT_PAYMENT
  AGGREGATOR_ADVANCE
}

enum StockTransactionType {
  IN
  OUT
  ADJUSTMENT
}

enum CustomerRole {
  BUYER
  DEBTOR
  AGGREGATOR
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum OrderSource {
  WEBSITE
  WALK_IN
  PHONE
}

enum CreditType {
  FIXED_DATE
  SEASONAL
}

enum CreditStatus {
  ACTIVE
  PARTIALLY_PAID
  PAID
  OVERDUE
  DEFAULTED
  RETURNED
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  AGREEMENT_SENT
  AGREEMENT_UPLOADED
  AGREEMENT_SIGNED
  SUPPLIED
  COMPLETED
}

enum NotificationType {
  ORDER_NEW
  ORDER_UPDATED
  PAYMENT_CONFIRMED
  LOW_STOCK
  CREDIT_OVERDUE
  TRANSFER_REQUEST
  AGGREGATOR_NEW
  SYSTEM
}
